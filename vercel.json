{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|manifest\\.json|sw\\.js|icons/|fuji\\.png|widget-data\\.json|widget-template\\.json).*)",
      "destination": "/index.html"
    }
  ]
}
